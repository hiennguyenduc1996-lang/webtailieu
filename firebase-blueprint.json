{
  "entities": {
    "Document": {
      "title": "Document",
      "description": "A study document or exam paper",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "author": { "type": "string" },
        "driveLink": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "category": { "type": "string", "enum": ["latest", "provincial", "specialized", "thematic", "prediction", "exam", "placeholder"] },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" },
        "description": { "type": "string" }
      },
      "required": ["title", "driveLink", "category", "createdAt", "updatedAt"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "fullName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] }
      },
      "required": ["uid", "email", "role", "status"]
    },
    "Comment": {
      "title": "Comment",
      "description": "User comment on a document",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "documentId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["documentId", "userId", "userName", "content", "createdAt"]
    },
    "RegistrationRequest": {
      "title": "RegistrationRequest",
      "description": "User registration request for admin approval",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "username": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "number" }
      },
      "required": ["fullName", "username", "status", "createdAt"]
    }
  },
  "firestore": {
    "/documents/{docId}": {
      "schema": "Document",
      "description": "Collection of documents"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Collection of user profiles"
    },
    "/comments/{commentId}": {
      "schema": "Comment",
      "description": "Collection of comments"
    },
    "/registration_requests/{requestId}": {
      "schema": "RegistrationRequest",
      "description": "Collection of registration requests"
    }
  }
}
